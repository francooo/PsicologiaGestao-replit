# Banco de dados (obrigatório)
# Use o endpoint "pooled" do Neon (host com "-pooler") em produção no Vercel.
DATABASE_URL=

# Sessão (obrigatório em produção — o código tem um fallback inseguro só para dev local)
SESSION_SECRET=

# IA / análise de notas fiscais (obrigatório para os recursos de IA)
GROQ_API_KEY=

# Envio de e-mail / recuperação de senha (obrigatório para esse fluxo)
RESEND_API_KEY=

# URL pública da aplicação em produção (obrigatório fora do Replit/local)
# Ex.: https://seu-projeto.vercel.app
APP_URL=
BASE_URL=

# Login com Google / Google Calendar (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# WhatsApp (opcional)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_TOKEN=

# Cosmético (opcional, default "ConsultaPsi")
CLINIC_NAME=

# Não definir em produção no Vercel:
# PORT (só usado pelo .listen() local)
# REPL_ID (deve ficar ausente fora do Replit)
